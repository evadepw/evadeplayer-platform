# EvadePlayer configuration reference.
# ./setup.sh generates .env interactively (or non-interactively with --yes);
# this file documents every variable and its default.

# Deploy mode: all-in-one | api | worker (informational; set by setup.sh)
DEPLOY_MODE=all-in-one
# Compose files used by `docker compose` / make (set by setup.sh)
COMPOSE_FILE=docker-compose.yml:docker-compose.override.yml

# --- PostgreSQL ---------------------------------------------------------------
# The database is also the transcoding queue: remote workers connect to it
# directly, so DB_PORT is exposed on the host in api mode.
POSTGRES_USER=evadeplayer
POSTGRES_PASSWORD=
POSTGRES_DB=evadeplayer
DB_HOST=postgres
DB_PORT=5432
DB_SSLMODE=disable

# --- SeaweedFS ----------------------------------------------------------------
SEAWEEDFS_FILER=http://seaweedfs-filer:8888
# Host-mapped ports (workers on other machines connect through these)
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_FILER_PORT=8888
# Address the volume server advertises to clients. Keep the Docker-internal
# default for all-in-one; for api mode set <this-server-ip>:<SEAWEEDFS_VOLUME_PORT>.
SEAWEEDFS_VOLUME_PUBLICURL=seaweedfs-volume:8080

# --- API ----------------------------------------------------------------------
API_PORT=8000
NGINX_PORT=80
# Public base URL used in returned manifest/preview links (no trailing slash)
PUBLIC_HOST=http://localhost
CORS_ORIGINS=*
MAX_UPLOAD_SIZE_GB=50
# debug | info | warn | error
LOG_LEVEL=info

# --- Auth ---------------------------------------------------------------------
# Upload always requires the X-Service-Key header.
SERVICE_KEY=
# true = GET /videos/* is public; false = X-Service-Key required for reads too
READ_PUBLIC=true
# true: HLS manifest and segment URLs carry HMAC-signed expiring tokens
HLS_REQUIRE_TOKEN=true
HLS_TOKEN_SECRET=

# --- Transcoder ---------------------------------------------------------------
# Concurrent transcodes on this machine (each worker machine sets its own)
TRANSCODE_WORKERS=2
# How many times a video may be attempted before it is marked failed
TRANSCODE_MAX_ATTEMPTS=3
TRANSCODE_TEMP_DIR=/tmp/evadeplayer
TRANSCODE_HLS_SEGMENT_SECONDS=4
# cpu | nvidia | vaapi
TRANSCODE_ACCEL=cpu
TRANSCODE_CODECS=h264,h265,av1
TRANSCODE_QUALITIES=360p,720p,1080p,1440p,original
# Per-quality video bitrate overrides (empty = defaults)
TRANSCODE_QUALITY_360P_BITRATE=
TRANSCODE_QUALITY_720P_BITRATE=
TRANSCODE_QUALITY_1080P_BITRATE=
TRANSCODE_QUALITY_1440P_BITRATE=

# Thumbnails / storyboard sprites
TRANSCODE_PREVIEW_WIDTH=640
TRANSCODE_PREVIEW_HEIGHT=360
TRANSCODE_SPRITE_WIDTH=320
TRANSCODE_SPRITE_HEIGHT=180
TRANSCODE_SPRITE_COLUMNS=10
TRANSCODE_SPRITE_INTERVAL_SECONDS=10
TRANSCODE_IMAGE_STREAM_BANDWIDTH=30000

# Encoding quality
# CPU preset (libx264/libx265): ultrafast … veryslow
TRANSCODE_PRESET=slow
# NVIDIA NVENC preset: p1 (fastest) … p7 (best quality)
TRANSCODE_NVIDIA_PRESET=p5
# CRF (variable bitrate): 0 = off (fixed bitrate). H.264: 20–24, H.265: 24–28.
TRANSCODE_H264_CRF=0
TRANSCODE_H265_CRF=0
# AV1 (libaom, cpu only): CRF 0–63; cpu-used 0 = best quality, 8 = fastest
TRANSCODE_AV1_CRF=30
TRANSCODE_AV1_CPU_USED=4
# 48000 = video standard, 44100 = CD
TRANSCODE_AUDIO_SAMPLE_RATE=48000
# Extra keyframes at scene cuts (better seeking, slightly larger files)
TRANSCODE_SCENE_CUT=false

# Started services profile: "transcoder" enables the local worker (all-in-one)
COMPOSE_PROFILES=transcoder
